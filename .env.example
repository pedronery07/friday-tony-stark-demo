# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq AI API key (STT — free tier at https://console.groq.com)
GROQ_API_KEY=

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Deepgram API key (TTS — free tier at https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Google Gemini API key (LLM — get from https://aistudio.google.com/projects)
GOOGLE_API_KEY=

# Google Cloud credentials (used when STT_PROVIDER = "google")
GOOGLE_APPLICATION_CREDENTIALS=

# ── Weather ────────────────────────────────────────────────────────────────────
# Free API key from https://openweathermap.org/api (sign up → Current Weather API)
OPENWEATHERMAP_API_KEY=
# City to use as default for weather queries
WEATHER_CITY=

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Your GitHub username (public activity works without a token)
GITHUB_USERNAME=
# Optional: personal access token for private repos (Settings → Developer settings → Tokens)
GITHUB_TOKEN=

# ── Google Calendar ────────────────────────────────────────────────────────────
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Desktop app type)
# 3. Download the JSON → save to ~/.friday/google_credentials.json
# 4. Run the MCP server once — it will open a browser for you to authorize
# Token is auto-saved to ~/.friday/google_token.json after first auth

# ── Supabase (optional) ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=